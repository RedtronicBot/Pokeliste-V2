generator client {
  provider     = "prisma-client"
  output       = "./generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model Set {
  id        String  @id
  name      String
  logo      String?
  symbol    String?
  cardCount Int
  seriesId  String
  series    Series  @relation(fields: [seriesId], references: [id])
  position  Int
  cards     Card[]
}

model Card {
  id            String         @id
  setId         String
  sets          Set            @relation(fields: [setId], references: [id])
  image         String
  name          String
  localId       Int
  ownedVariants OwnedVariant[]
}

model OwnedVariant {
  id            Int    @id @default(autoincrement())
  cardId        String @unique
  card          Card   @relation(fields: [cardId], references: [id])
  normal        Int
  holo          Int
  reverse       Int
  firstEdition  Int
  secondEdition Int
}

model Series {
  id       String  @id
  name     String
  logo     String?
  position Int
  sets     Set[]
}
