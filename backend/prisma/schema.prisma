generator client {
  provider     = "prisma-client"
  output       = "./generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model Set {
  id        String  @id
  name      String
  logo      String?
  symbol    String?
  cardCount Int
  seriesId  String
  series    Series  @relation(fields: [seriesId], references: [id])
  position  Int
  cards     Card[]
}

model Card {
  id            String         @id
  setId         String
  sets          Set            @relation(fields: [setId], references: [id])
  image         String
  name          String
  localId       Int
  ownedVariants OwnedVariant[]
}

model OwnedVariant {
  id            String @id @default(uuid())
  userId        String
  user          User   @relation(fields: [userId], references: [id])
  cardId        String
  card          Card   @relation(fields: [cardId], references: [id])
  normal        Int
  holo          Int
  reverse       Int
  firstEdition  Int
  secondEdition Int

  @@unique([userId, cardId])
}

model Series {
  id       String  @id
  name     String
  logo     String?
  position Int
  sets     Set[]
}

model User {
  id            String         @id @default(uuid())
  discordId     String         @unique
  username      String
  avatar        String?
  ownedVariants OwnedVariant[]
}
